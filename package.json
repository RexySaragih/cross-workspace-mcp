{
  "name": "@rexymayderio/cross-workspace-mcp",
  "version": "1.2.0",
  "description": "MCP server for reading, writing, and diagnosing files across multiple project workspaces",
  "type": "module",
  "bin": {
    "cross-workspace-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "workspace",
    "cross-project",
    "ai-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RexySaragih/cross-workspace-mcp.git"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "typescript": "^5.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
